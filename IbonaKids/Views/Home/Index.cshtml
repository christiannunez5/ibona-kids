@model IEnumerable<IbonaKids.Models.Product>
@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .hero-section {
        background-color: #111;
        color: #fff;
        padding: 100px 0;
        position: relative;
        overflow: hidden;
    }

        .hero-section::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -10%;
            width: 500px;
            height: 500px;
            border-radius: 50%;
            background: rgba(255,255,255,0.03);
            pointer-events: none;
        }

    .hero-eyebrow {
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: #aaa;
        margin-bottom: 1rem;
    }

    .hero-title {
        font-size: clamp(2.5rem, 6vw, 4rem);
        font-weight: 700;
        line-height: 1.1;
        letter-spacing: -0.02em;
        margin-bottom: 1.25rem;
    }

        .hero-title span {
            font-weight: 300;
            color: #aaa;
        }

    .hero-subtitle {
        font-size: 1rem;
        font-weight: 300;
        color: #888;
        max-width: 420px;
        margin: 0 auto 2rem;
        line-height: 1.7;
    }

    .btn-hero-primary {
        background: #fff;
        color: #111;
        border: none;
        border-radius: 50px;
        padding: 0.7rem 2rem;
        font-size: 0.875rem;
        font-weight: 600;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        transition: background 0.2s, color 0.2s;
        text-decoration: none;
    }

        .btn-hero-primary:hover {
            background: #ddd;
            color: #111;
        }

    .btn-hero-secondary {
        background: transparent;
        color: #aaa;
        border: 1px solid #333;
        border-radius: 50px;
        padding: 0.7rem 2rem;
        font-size: 0.875rem;
        font-weight: 500;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        transition: border-color 0.2s, color 0.2s;
        text-decoration: none;
    }

        .btn-hero-secondary:hover {
            border-color: #888;
            color: #fff;
        }

    .section-title {
        font-size: 1.5rem;
        font-weight: 700;
        letter-spacing: -0.01em;
        color: #111;
    }

    .section-divider {
        width: 40px;
        height: 3px;
        background: #111;
        margin-bottom: 2rem;
    }
</style>

<section class="hero-section text-center">
    <div class="container">
        <p class="hero-eyebrow">Premium PC Peripherals</p>
        <h1 class="hero-title">
            Level Up Your <span>Setup</span>
        </h1>
        <p class="hero-subtitle">
            Discover our curated collection of mice, keyboards, headsets, and more — built for performance.
        </p>
        <div class="d-flex justify-content-center gap-3 flex-wrap">
            <a asp-controller="Products" asp-action="Index" class="btn-hero-primary">Shop Now</a>
            <a href="#featured" class="btn-hero-secondary">View Featured</a>
        </div>
    </div>
</section>

<section class="py-5"" id="featured">
    <div class="container">
        <div class="mb-4">
            <h2 class="section-title">Featured Products</h2>
            <div class="section-divider"></div>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="row row-cols-2 row-cols-md-3 g-3">
                @foreach (var product in Model)
                {
                    <div class="col">
                        @await Html.PartialAsync("_ProductCard", product)
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center text-muted py-5">
                <p class="mt-3" style="font-size:0.95rem;">No products available yet.</p>
            </div>
        }
    </div>
</section>