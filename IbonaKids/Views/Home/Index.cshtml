@{
    ViewData["Title"] = "Home Page";
}

<div class="bg-dark text-white rounded-4 p-5 mb-4">
    <span class="badge bg-primary mb-3">Free shipping on orders over $50</span>
    <h1 class="fw-bold display-6 mb-3">Discover products<br>you'll love.</h1>
    <p class="text-secondary mb-4" style="max-width:460px;">
        Shop thousands of curated items across electronics, fashion, home goods, and more. New arrivals every week.
    </p>
    <div class="d-flex gap-2 flex-wrap">
        <a href="/Products" class="btn btn-primary px-4">Shop now</a>
        <a href="/Products?sale=true" class="btn btn-outline-light px-4">View deals</a>
    </div>
</div>

<section class="chart-table-page">
    <h1>Simple Chart Table</h1>
    <p>This table shows the basic database tables used in the project.</p>

    <div class="table-responsive">
        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>No.</th>
                    <th>Table Name</th>
                    <th>Columns</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>1</td>
                    <td>product_categories</td>
                    <td>id, name</td>
                </tr>
                <tr>
                    <td>2</td>
                    <td>users</td>
                    <td>id, username, email_address, password, role, balance</td>
                </tr>
                <tr>
                    <td>3</td>
                    <td>products</td>
                    <td>id, name, price, image, is_active, stock_quantity, product_category_id, created_by_id</td>
                </tr>
                <tr>
                    <td>4</td>
                    <td>cart</td>
                    <td>id, quantity, added_at, product_id, user_id</td>
                </tr>
                <tr>
                    <td>5</td>
                    <td>orders</td>
                    <td>id, total_amount, created_at, status, user_id</td>
                </tr>
                <tr>
                    <td>6</td>
                    <td>order_items</td>
                    <td>id, quantity, unit_price, order_id, product_id</td>
                </tr>
            </tbody>
        </table>
    </div>
</section>
