@using IbonaKids.ViewModels
@model LoginViewModel

<div class="d-flex justify-content-center align-items-center" style="margin-top: 230px">

    <div class="card shadow-lg border-0 w-100" style="max-width: 420px;">

        <div class="card-body p-4">

            <h3 class="text-center fw-semibold mb-1">Welcome Back</h3>
            <p class="text-center text-muted mb-4">Sign in to continue</p>

            <form asp-action="Login" method="post">

                <div class="form-floating mb-3">
                    <input asp-for="Email" type="email" class="form-control" id="emailInput" placeholder="Email">
                    <label asp-for="Email"></label>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Password" type="password" class="form-control" id="passwordInput" placeholder="Password">
                    <label asp-for="Password"></label>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-3"></div>

                <button type="submit" class="btn btn-primary w-100 py-2">
                    Login
                </button>

                <div class="text-center mt-3">
                    <small class="text-muted">
                        Don't have an account?
                        <a asp-action="Register" class="text-decoration-none">Register</a>
                    </small>
                </div>

            </form>

        </div>
    </div>
</div>