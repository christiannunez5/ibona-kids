@using IbonaKids.ViewModels

@model NavbarViewModel

<header>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm bg-white border-bottom mb-3" style="font-family: 'Raleway', sans-serif;">
        <div class="container-fluid px-4">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <!-- Sidebar Toggle -->
                <button class="btn btn-outline-secondary btn-sm me-3 border-0" type="button"
                        data-bs-toggle="offcanvas" data-bs-target="#categorySidebar">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                        <path fill-rule="evenodd" d="M2.5 12a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5zm0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5zm0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5z" />
                    </svg>
                </button>
            }

            <!-- Brand -->
            <a class="navbar-brand fw-bold text-dark" style="font-size:1.3rem; letter-spacing:0.05em;"
               asp-area="" asp-controller="Home" asp-action="Index">
                IBONA<span class="fw-light">KIDS</span>
            </a>

            <!-- Mobile toggler -->
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse"
                    data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between align-items-center">
                <!-- Left links -->
                <ul class="navbar-nav flex-grow-1">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-medium" style="font-size:0.875rem;"
                               asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                    }
                </ul>

                <!-- Right side -->
                <ul class="navbar-nav align-items-center gap-2">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item d-flex align-items-center gap-2">
                            <img src="@(string.IsNullOrEmpty(Model.ProfileUrl) ? Url.Content("~/images/default-avatar.png") : Model.ProfileUrl)"
                                 alt="Profile"
                                 class="rounded-circle border"
                                 style="width: 34px; height: 34px; object-fit: cover;" />
                            <span class="nav-link text-muted" style="font-size:0.875rem;">
                                Hello, <strong class="text-dark">@User.Identity.Name</strong>
                            </span>
                        </li>

                        <li class="nav-item">
                            <span class="nav-link text-muted" style="font-size:0.875rem;">
                                Current Balance:
                                <strong class="text-dark">
                                    ₱@Model.Balance?.ToString("N2")
                                </strong>
                            </span>
                        </li>

                        <li class="nav-item">
                            <form asp-controller="Auth" asp-action="Logout" method="post">
                                <button type="submit" class="btn btn-dark btn-sm rounded-pill px-3"
                                        style="font-size:0.8rem;">
                                    Logout
                                </button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-medium" style="font-size:0.875rem;"
                               asp-controller="Auth" asp-action="Login">Login</a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-dark btn-sm rounded-pill px-3" style="font-size:0.8rem;"
                               asp-controller="Auth" asp-action="Register">Register</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>
</header>

<link href="https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;500;600;700&display=swap" rel="stylesheet">