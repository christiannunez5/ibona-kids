@model IbonaKids.Models.Product

<div class="card h-100 border-0 shadow-sm p-2 product-card"
     data-bs-toggle="modal"
     data-bs-target="#productModal"
     data-id="@Model.Id"
     data-name="@Model.Name"
     data-description="@Model.Description"
     data-price="@Model.Price"
     data-image="@Model.ImageUrl">

    @if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        <img src="@Model.ImageUrl" alt="@Model.Name"
             class="card-img-top rounded"
             style="aspect-ratio:1/1; object-fit:cover;" />
    }
    else
    {
        <div class="bg-light d-flex align-items-center justify-content-center rounded" style="aspect-ratio:1/1;">
            <i class="bi bi-image text-secondary fs-1"></i>
        </div>
    }

    <div class="card-body px-2 pt-2 pb-1">

        <div class="d-flex justify-content-between align-items-center mb-1">
            <small class="text-muted text-uppercase"
                   style="font-size:0.7rem; letter-spacing:0.05em;">
                @Model.ProductCategory?.Name
            </small>
        </div>

        <p class="card-title mb-1 fw-medium text-truncate" style="font-size:0.875rem;">
            @Model.Name
        </p>

        <div class="d-flex align-items-center justify-content-between mt-2">

            <div class="d-flex gap-2">
                <span class="fw-semibold" style="font-size:0.875rem;">
                    ₱@Model.Price.ToString("0.00")
                </span>

                @if (Model.StockQuantity > 10)
                {
                    <span class="badge bg-success rounded-pill px-3">
                        In Stock
                    </span>
                }
                else if (Model.StockQuantity > 0)
                {
                    <span class="badge bg-warning text-dark rounded-pill px-3">
                        Low (@Model.StockQuantity)
                    </span>
                }
                else
                {
                    <span class="badge bg-danger text-dark rounded-pill px-3">
                        Out
                    </span>
                }

            </div>

            <form asp-controller="Cart" asp-action="Add" method="post"
                  onclick="event.stopPropagation();">

                <input type="hidden" name="productId" value="@Model.Id" />

                <button type="submit"
                        class="btn btn-dark btn-sm rounded-pill px-3"
                        style="font-size:0.75rem;"
                        @(Model.StockQuantity <= 0 ? "disabled" : "")>
                    Add to Cart
                </button>
            </form>

        </div>
    </div>
</div>